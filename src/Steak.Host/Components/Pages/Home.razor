@page "/"
@inject ILogger<Home> Logger
@inject ITopicBrowserService TopicBrowserService

<PageTitle>Steak</PageTitle>

<div class="workspace-shell">
    <section class="connection-card surface">
        <div class="connection-header">
            <div>
                <p class="section-kicker">Connections</p>
                <h2>@(_sessions.Count > 0 ? $"{_sessions.Count} active" : "Not connected")</h2>
            </div>
            <div class="connection-actions">
                <a class="ghost-button" href="/swagger" target="_blank" rel="noreferrer">Swagger</a>
                @if (_showConnectForm && _sessions.Count > 0)
                {
                    <button class="ghost-button" @onclick="@(() => _showConnectForm = false)">Cancel</button>
                }
                @if (!_showConnectForm)
                {
                    <button class="primary-button" @onclick="@(() => _showConnectForm = true)">+ New Connection</button>
                }
            </div>
        </div>

        @if (_showConnectForm)
        {
            <div class="connect-form">
                <div class="form-grid">
                    <label>
                        <span>Bootstrap Servers <span class="tooltip-icon">?<span class="tooltip-text">Comma-separated list of Kafka broker addresses.
Each entry is host:port. The client will discover
the full cluster from any reachable broker.
Example: broker-1:9092,broker-2:9092
Usually your cluster's advertised listeners.</span></span></span>
                        <input @bind="_settings.BootstrapServers" placeholder="broker-1:9092,broker-2:9092" />
                    </label>
                    <label>
                        <span>Username @GetCredentialRequirementLabel() <span class="tooltip-icon">?<span class="tooltip-text">SASL username for authenticating to the cluster.
Used with SASL_PLAINTEXT or SASL_SSL protocols.
Also used as a default Client Id and Consumer Group
if those fields are left empty.
Typically an ACL principal or service account.</span></span></span>
                        <input @bind="_settings.Username" placeholder="" />
                    </label>
                    <label>
                        <span>Password @GetCredentialRequirementLabel() <span class="tooltip-icon">?<span class="tooltip-text">SASL password paired with the username above.
Sent during the SASL handshake before any data flows.
Keep this secret — it is never stored to disk.
For SCRAM mechanisms the password is hashed.
For PLAIN it is sent in cleartext (use SSL).</span></span></span>
                        <input type="password" @bind="_settings.Password" />
                    </label>
                    <label>
                        <span>Security Protocol <span class="tooltip-icon">?<span class="tooltip-text">Determines encryption and authentication mode.
SASL_SSL — SASL auth over TLS (recommended for prod).
SASL_PLAINTEXT — SASL auth without encryption.
SSL — TLS mutual auth with client certificates.
PLAINTEXT — no encryption or SASL (dev only).</span></span></span>
                        <select @bind="_settings.SecurityProtocol">
                            <option value="SaslPlaintext">SASL_PLAINTEXT</option>
                            <option value="SaslSsl">SASL_SSL</option>
                            <option value="Ssl">SSL</option>
                            <option value="Plaintext">PLAINTEXT</option>
                        </select>
                    </label>
                    <label>
                        <span>SASL Mechanism <span class="tooltip-icon">?<span class="tooltip-text">Authentication algorithm used during SASL handshake.
SCRAM-SHA-256 — QaaS-compatible default and common cluster setting.
SCRAM-SHA-512 — stronger hash variant when the cluster requires it.
PLAIN — simple username/password (needs SSL).
OAUTHBEARER / GSSAPI — token or Kerberos auth.</span></span></span>
                        <select @bind="_settings.SaslMechanism">
                            <option value="Plain">PLAIN</option>
                            <option value="ScramSha256">SCRAM-SHA-256</option>
                            <option value="ScramSha512">SCRAM-SHA-512</option>
                            <option value="OAuthBearer">OAUTHBEARER</option>
                            <option value="Gssapi">GSSAPI (Kerberos)</option>
                        </select>
                    </label>
                    <label>
                        <span>Client Id (defaults to username) <span class="tooltip-icon">?<span class="tooltip-text">Identifier sent to brokers for monitoring/logging.
Appears in broker logs and connection metrics.
Defaults to username when left blank.
Useful for distinguishing multiple Steak instances
connecting with the same credentials.</span></span></span>
                        <input @bind="_settings.ClientId" placeholder="(uses username)" />
                    </label>
                </div>

                <details class="advanced-toggle">
                    <summary>Advanced settings</summary>
                    <div class="form-grid">
                        <label>
                            <span>SSL CA PEM <span class="tooltip-icon">?<span class="tooltip-text">PEM-encoded Certificate Authority certificate.
Used to verify the broker's TLS certificate.
Required when brokers use private/self-signed CAs.
Paste the full PEM including BEGIN/END markers.
Leave blank if your system CA store is sufficient.</span></span></span>
                            <textarea rows="3" @bind="_settings.SslCaPem"></textarea>
                        </label>
                        <label>
                            <span>SSL Certificate PEM <span class="tooltip-icon">?<span class="tooltip-text">PEM-encoded client certificate for mutual TLS.
Sent to the broker so it can verify this client.
Required when the cluster enforces mTLS.
Paste the full certificate chain if needed.
Used with the SSL or SASL_SSL protocols.</span></span></span>
                            <textarea rows="3" @bind="_settings.SslCertificatePem"></textarea>
                        </label>
                        <label>
                            <span>SSL Key PEM <span class="tooltip-icon">?<span class="tooltip-text">PEM-encoded private key matching the client certificate.
Used for mutual TLS authentication with the broker.
Must correspond to the SSL Certificate PEM above.
Paste the full key including BEGIN/END markers.
Protect this value — it authenticates this client.</span></span></span>
                            <textarea rows="3" @bind="_settings.SslKeyPem"></textarea>
                        </label>
                        <label>
                            <span>SSL Key Password <span class="tooltip-icon">?<span class="tooltip-text">Passphrase to decrypt the SSL private key PEM.
Required only if the key PEM is encrypted.
Leave blank if the key is in plain PEM format.
Stored in memory only — never persisted to disk.
Common when keys are exported from Java keystores.</span></span></span>
                            <input type="password" @bind="_settings.SslKeyPassword" />
                        </label>
                    </div>
                    <label class="wide-field">
                        <span>Advanced Overrides (key=value per line) <span class="tooltip-icon">?<span class="tooltip-text">Raw librdkafka configuration properties.
One key=value pair per line.
Overrides any auto-configured settings above.
See confluent-kafka docs for all available keys.
Example: request.timeout.ms=10000</span></span></span>
                        <textarea rows="3" @bind="_advancedOverrideText" placeholder="request.timeout.ms=10000"></textarea>
                    </label>
                </details>

                <div class="button-row">
                    <button class="primary-button" @onclick="ConnectAsync"
                            disabled="@(!CanConnect())">
                        @if (_connecting)
                        {
                            <span>Connecting...</span>
                        }
                        else
                        {
                            @(_editingSessionId is not null ? "Reconnect" : "Connect")
                        }
                    </button>
                    @if (_editingSessionId is not null)
                    {
                        <button class="ghost-button" @onclick="@(() => { _editingSessionId = null; _showConnectForm = false; _settings = new KafkaConnectionSettings(); })">Cancel Edit</button>
                    }
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="inline-alert danger">@_error</div>
        }
    </section>

    @if (_sessions.Count > 0)
    {
        <section class="surface workspace-surface">
            <div class="tab-strip" role="tablist" aria-label="Connection tabs">
                @foreach (var session in _sessions)
                {
                    <button class="@GetConnectionTabClass(session.ConnectionSessionId!)"
                            @onclick="@(() => SwitchConnection(session.ConnectionSessionId!))">
                        @session.BootstrapServers
                        <span class="tab-edit" @onclick="@(() => EditConnection(session.ConnectionSessionId!))" @onclick:stopPropagation="true">&#9998;</span>
                        <span class="tab-close" @onclick="@(() => DisconnectSessionAsync(session.ConnectionSessionId!))" @onclick:stopPropagation="true">&times;</span>
                    </button>
                }
            </div>

            @if (_activeSession is not null)
            {
                <div class="tab-strip" role="tablist" aria-label="Steak workspaces">
                    <button class="@GetTabClass("view")" @onclick="@(() => _activeTab = "view")">View</button>
                    <button class="@GetTabClass("consume")" @onclick="@(() => _activeTab = "consume")">Consume</button>
                    <button class="@GetTabClass("publish")" @onclick="@(() => _activeTab = "publish")">Publish</button>
                </div>

                @if (_activeTab == "view")
                {
                    <ViewWorkspace ConnectionSessionId="@_activeSession.ConnectionSessionId" OnSessionLost="HandleSessionLost" />
                }
                else if (_activeTab == "consume")
                {
                    <ConsumeWorkspace ConnectionSessionId="@_activeSession.ConnectionSessionId" OnSessionLost="HandleSessionLost" Username="@_activeSession.Username" />
                }
                else
                {
                    <PublishWorkspace ConnectionSessionId="@_activeSession.ConnectionSessionId" OnSessionLost="HandleSessionLost" />
                }
            }
        </section>
    }
</div>

@code {
    private string _activeTab = "view";
    private string? _error;
    private string _advancedOverrideText = string.Empty;
    private bool _showConnectForm = true;
    private string? _editingSessionId;
    private bool _connecting;
    private KafkaConnectionSettings _settings = new();
    private List<ConnectionSessionStatus> _sessions = [];
    private ConnectionSessionStatus? _activeSession;

    [Inject]
    private IConnectionSessionService SessionService { get; set; } = default!;

    protected override void OnInitialized()
    {
        _sessions = SessionService.GetAllSessions().ToList();
        _activeSession = _sessions.FirstOrDefault();
        if (_sessions.Count > 0) _showConnectForm = false;
    }

    private async Task ConnectAsync()
    {
        try
        {
            _error = null;
            _connecting = true;
            StateHasChanged();

            _settings.AdvancedOverrides = string.IsNullOrWhiteSpace(_advancedOverrideText)
                ? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                : KeyValueTextParser.Parse(_advancedOverrideText);

            var requiresSasl = RequiresSasl(_settings.SecurityProtocol);

            // Auto-set security protocol and mechanism for SASL when not set.
            if (string.IsNullOrWhiteSpace(_settings.SecurityProtocol))
            {
                _settings.SecurityProtocol = "SaslPlaintext";
            }
            if (requiresSasl && string.IsNullOrWhiteSpace(_settings.SaslMechanism))
            {
                _settings.SaslMechanism = "ScramSha256";
            }

            if (requiresSasl)
            {
                Logger.LogInformation(
                    "Kafka connection attempt requested from UI for {BootstrapServers} as user {Username}",
                    _settings.BootstrapServers,
                    _settings.Username);
            }
            else
            {
                Logger.LogInformation(
                    "Kafka connection attempt requested from UI for {BootstrapServers} without SASL credentials",
                    _settings.BootstrapServers);
            }

            // If editing, disconnect the old session first
            if (!string.IsNullOrWhiteSpace(_editingSessionId))
            {
                SessionService.Disconnect(_editingSessionId);
                _editingSessionId = null;
            }

            var response = SessionService.Connect(new ConnectRequest { Settings = _settings });

            // Validate connection by actually reaching the cluster.
            try
            {
                await TopicBrowserService.ListTopicsAsync(response.ConnectionSessionId).ConfigureAwait(false);
            }
            catch (Exception exception)
            {
                SessionService.Disconnect(response.ConnectionSessionId);
                Logger.LogError(
                    exception,
                    "Kafka connection validation failed for UI session {SessionId}",
                    response.ConnectionSessionId);
                throw new InvalidOperationException(
                    UiErrorMessage.Build(
                        "Unable to connect to the Kafka cluster. Verify the bootstrap servers, credentials, security protocol, and network path.",
                        exception),
                    exception);
            }

            Logger.LogInformation(
                "Kafka connection validated successfully for UI session {SessionId}",
                response.ConnectionSessionId);

            _sessions = SessionService.GetAllSessions().ToList();
            _activeSession = _sessions.FirstOrDefault(s => s.ConnectionSessionId == response.ConnectionSessionId);
            _settings = new KafkaConnectionSettings();
            _advancedOverrideText = string.Empty;
            _showConnectForm = false;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Kafka connection attempt failed from the UI");
            _error = exception.Message;
        }
        finally
        {
            _connecting = false;
        }
    }

    private Task DisconnectSessionAsync(string sessionId)
    {
        try
        {
            SessionService.Disconnect(sessionId);
            _sessions = SessionService.GetAllSessions().ToList();
            if (_activeSession?.ConnectionSessionId == sessionId)
            {
                _activeSession = _sessions.FirstOrDefault();
            }
            if (_sessions.Count == 0)
            {
                _showConnectForm = true;
                _activeSession = null;
            }
            _error = null;
        }
        catch (Exception exception)
        {
            Logger.LogError(exception, "Disconnect session request failed for session {SessionId}", sessionId);
            _error = UiErrorMessage.Build("Disconnect session", exception);
        }

        return Task.CompletedTask;
    }

    private void SwitchConnection(string sessionId)
    {
        _activeSession = _sessions.FirstOrDefault(s => s.ConnectionSessionId == sessionId);
    }

    private string GetConnectionTabClass(string sessionId)
    {
        return _activeSession?.ConnectionSessionId == sessionId ? "tab-button active" : "tab-button";
    }

    private string GetTabClass(string tab)
    {
        return _activeTab == tab ? "tab-button active" : "tab-button";
    }

    private void EditConnection(string sessionId)
    {
        var session = _sessions.FirstOrDefault(s => s.ConnectionSessionId == sessionId);
        if (session is null) return;

        _editingSessionId = sessionId;
        var current = SessionService.GetActiveSettings(sessionId);
        _settings = new KafkaConnectionSettings
        {
            BootstrapServers = current.BootstrapServers,
            Username = current.Username,
            Password = current.Password,
            SecurityProtocol = current.SecurityProtocol,
            SaslMechanism = current.SaslMechanism,
            ClientId = current.ClientId,
            SslCaPem = current.SslCaPem,
            SslCertificatePem = current.SslCertificatePem,
            SslKeyPem = current.SslKeyPem,
            SslKeyPassword = current.SslKeyPassword,
            AdvancedOverrides = new Dictionary<string, string>(current.AdvancedOverrides, StringComparer.OrdinalIgnoreCase)
        };
        _advancedOverrideText = string.Join(
            Environment.NewLine,
            _settings.AdvancedOverrides
                .OrderBy(pair => pair.Key, StringComparer.OrdinalIgnoreCase)
                .Select(pair => $"{pair.Key}={pair.Value}"));
        _showConnectForm = true;
    }

    private void HandleSessionLost(string? sessionId)
    {
        _sessions = SessionService.GetAllSessions().ToList();
        if (!string.IsNullOrWhiteSpace(sessionId))
        {
            _sessions.RemoveAll(s => s.ConnectionSessionId == sessionId);
        }
        _activeSession = _sessions.FirstOrDefault();
        if (_sessions.Count == 0)
        {
            _showConnectForm = true;
            _activeSession = null;
            _error = "Connection session was lost. The server no longer has the selected Kafka session. Please reconnect.";
        }
    }

    private bool CanConnect()
    {
        if (_connecting || string.IsNullOrWhiteSpace(_settings.BootstrapServers))
        {
            return false;
        }

        if (!RequiresSasl(_settings.SecurityProtocol))
        {
            return true;
        }

        return !string.IsNullOrWhiteSpace(_settings.Username)
            && !string.IsNullOrWhiteSpace(_settings.Password);
    }

    private string GetCredentialRequirementLabel()
    {
        return RequiresSasl(_settings.SecurityProtocol) ? "(required for SASL)" : "(optional)";
    }

    private static bool RequiresSasl(string? securityProtocol)
    {
        if (string.IsNullOrWhiteSpace(securityProtocol))
        {
            return true;
        }

        var normalized = new string(securityProtocol.Where(char.IsLetterOrDigit).ToArray()).ToUpperInvariant();
        return normalized is "SASLPLAINTEXT" or "SASLSSL";
    }
}
