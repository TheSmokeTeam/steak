@implements IDisposable
@inject ITopicBrowserService TopicBrowserService
@inject IViewSessionService ViewSessionService

<div class="workspace-panel">
    <div class="panel-header">
        <div>
            <p class="section-kicker">View</p>
            <h2>Live message viewer</h2>
        </div>
        <button class="ghost-button" disabled="@string.IsNullOrWhiteSpace(ConnectionSessionId)" @onclick="RefreshTopicsAsync">Refresh Topics</button>
    </div>

    <div class="control-grid">
        <label>
            <span>Topic Filter <span class="tooltip-icon">?<span class="tooltip-text">Type to filter the topic list below.
Matches any part of the topic name.
Useful when the cluster has hundreds of topics.
The filter is case-insensitive.
Clear the field to show all topics.</span></span></span>
            <input @bind="_topicFilter" placeholder="search topics" />
        </label>
        <label>
            <span>Topic <span class="tooltip-icon">?<span class="tooltip-text">Select the Kafka topic to stream messages from.
Only topics matching the filter above are shown.
You must select a topic before starting live view.
Partition and offset options update automatically.
Refresh Topics to reload the list from the cluster.</span></span></span>
            <select @bind="_selectedTopic">
                <option value="">Select topic</option>
                @foreach (var topic in FilteredTopics)
                {
                    <option value="@topic.Name">@topic.Name</option>
                }
            </select>
        </label>
        <label>
            <span>Partition <span class="tooltip-icon">?<span class="tooltip-text">Choose a specific partition or "All partitions".
Selecting a single partition reduces noise.
Partition IDs are 0-based integers.
The list is populated from the selected topic.
"All" streams from every partition simultaneously.</span></span></span>
            <select @bind="_selectedPartitionValue">
                <option value="">All partitions</option>
                @if (SelectedTopicSummary is not null)
                {
                    @foreach (var partition in SelectedTopicSummary.Partitions)
                    {
                        <option value="@partition.PartitionId">@partition.PartitionId</option>
                    }
                }
            </select>
        </label>
        <label>
            <span>Offset Mode <span class="tooltip-icon">?<span class="tooltip-text">Where to start reading messages in the partition.
Earliest — read all historical messages from the start.
Latest — only see new messages arriving after start.
Stored — resume from the last committed offset.
Timestamp — start from a specific point in time.</span></span></span>
            <select @bind="_offsetMode">
                @foreach (var mode in Enum.GetValues<MessageOffsetMode>())
                {
                    <option value="@mode">@mode</option>
                }
            </select>
        </label>
        <label>
            <span>Group Id (optional) <span class="tooltip-icon">?<span class="tooltip-text">Consumer group for offset tracking.
Leave blank for an ephemeral viewer (no commits).
Setting a group lets "Stored" offset mode resume.
Multiple viewers sharing a group split partitions.
Useful for bookmarking your read position.</span></span></span>
            <input @bind="_groupId" placeholder="leave blank for ephemeral viewer" />
        </label>
        <label>
            <span>Message Filter <span class="tooltip-icon">?<span class="tooltip-text">Search text applied to buffered messages.
Filters the message list in real-time.
Matches against key, value preview, and headers.
Case-insensitive substring match.
Does not affect what is consumed from Kafka.</span></span></span>
            <input @bind="_messageFilter" placeholder="search recent payloads" />
        </label>
    </div>

    <div class="button-row">
        @if (_sessionStatus.IsRunning)
        {
            <button class="stop-button" @onclick="StopAsync">&#9632; Stop Live View</button>
        }
        else
        {
            <button class="start-button" disabled="@(!CanStart)" @onclick="StartAsync">&#9654; Start Live View</button>
        }
        <span class="status-pill @(_sessionStatus.IsRunning ? "live" : "idle")">
            @(_sessionStatus.IsRunning ? $"Streaming {_sessionStatus.ReceivedCount} messages" : "Idle")
        </span>
    </div>

    <div class="metric-grid">
        <div class="metric-card"><strong>Topics</strong><span>@_topics.Count loaded</span></div>
        <div class="metric-card"><strong>Buffered messages</strong><span>@_sessionStatus.RecentMessages.Count shown</span></div>
        <div class="metric-card"><strong>Selected partition</strong><span>@(string.IsNullOrWhiteSpace(_selectedPartitionValue) ? "All" : _selectedPartitionValue)</span></div>
        <div class="metric-card"><strong>Offset mode</strong><span>@_offsetMode</span></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="inline-alert danger">@_error</div>
    }
    @if (!string.IsNullOrWhiteSpace(_sessionStatus.LastError))
    {
        <div class="inline-alert danger">@_sessionStatus.LastError</div>
    }

    <div class="workspace-columns">
        <section class="surface inner-surface">
            <div class="section-heading">
                <div><p class="section-kicker">Topics</p><h3>Connected session</h3></div>
            </div>
            <div class="topic-list">
                @if (string.IsNullOrWhiteSpace(ConnectionSessionId))
                {
                    <div class="empty-state compact">Connect first.</div>
                }
                else if (_loadingTopics)
                {
                    <div class="empty-state compact">Loading topic metadata...</div>
                }
                else if (FilteredTopics.Count == 0)
                {
                    <div class="empty-state compact">No topics match the current filter.</div>
                }
                else
                {
                    @foreach (var topic in FilteredTopics)
                    {
                        <button class="topic-tile @(topic.Name == _selectedTopic ? "active" : null)" @onclick="@(() => SelectTopic(topic.Name))">
                            <strong>@topic.Name</strong>
                            <span>@topic.PartitionCount partition(s)</span>
                        </button>
                    }
                }
            </div>
            @if (SelectedTopicSummary is not null)
            {
                <div class="metadata-list">
                    @foreach (var partition in SelectedTopicSummary.Partitions)
                    {
                        <div class="meta-card">
                            <strong>Partition @partition.PartitionId</strong>
                            <span>Leader: @partition.Leader</span>
                            <span>ISR: @string.Join(", ", partition.InSyncReplicas)</span>
                        </div>
                    }
                </div>
            }
        </section>

        <section class="surface inner-surface">
            <div class="section-heading">
                <div><p class="section-kicker">Recent messages</p><h3>@(_sessionStatus.Topic ?? "No active session")</h3></div>
                <span class="muted-label">@_sessionStatus.RecentMessages.Count buffered</span>
            </div>
            <div class="message-table">
                @if (FilteredMessages.Count == 0)
                {
                    <div class="empty-state compact">Start a view session to see recent messages here.</div>
                }
                else
                {
                    @foreach (var message in FilteredMessages)
                    {
                        <button class="message-row @(ReferenceEquals(message, _selectedMessage) ? "active" : null)"
                                @onclick="@(() => _selectedMessage = message)">
                            <span>@message.Partition:@message.Offset</span>
                            <strong>@(message.Preview?.ValueUtf8Preview ?? message.ValueBase64[..Math.Min(message.ValueBase64.Length, 42)])</strong>
                            <span>@message.TimestampUtc?.ToLocalTime().ToString("u")</span>
                            <span>@message.Headers.Count header(s) · @(message.Preview?.ValueIsJson == true ? "JSON" : message.Preview?.ValueIsUtf8 == true ? "UTF-8" : "Binary")</span>
                        </button>
                    }
                }
            </div>
        </section>
    </div>

    <section class="surface detail-surface">
        <div class="section-heading">
            <div><p class="section-kicker">Inspector</p><h3>@(_selectedMessage?.Topic ?? "Select a message")</h3></div>
        </div>
        @if (_selectedMessage is null)
        {
            <div class="empty-state">Choose a message to inspect its offsets, headers, base64, text, and JSON previews.</div>
        }
        else
        {
            <div class="detail-grid">
                <div class="meta-card"><strong>Topic</strong><span>@_selectedMessage.Topic</span></div>
                <div class="meta-card"><strong>Partition</strong><span>@_selectedMessage.Partition</span></div>
                <div class="meta-card"><strong>Offset</strong><span>@_selectedMessage.Offset</span></div>
                <div class="meta-card"><strong>Timestamp</strong><span>@_selectedMessage.TimestampUtc?.ToLocalTime().ToString("u")</span></div>
                <div class="meta-card"><strong>Headers</strong><span>@_selectedMessage.Headers.Count</span></div>
                <div class="meta-card"><strong>Payload</strong><span>@(_selectedMessage.Preview?.ValueIsJson == true ? "JSON" : _selectedMessage.Preview?.ValueIsUtf8 == true ? "UTF-8" : "Binary")</span></div>
            </div>
            <div class="detail-columns">
                <div>
                    <h4>Headers</h4>
                    <div class="header-list">
                        @if (_selectedMessage.Headers.Count == 0)
                        {
                            <div class="empty-state compact">No headers.</div>
                        }
                        else
                        {
                            @foreach (var header in _selectedMessage.Headers)
                            {
                                <div class="header-card">
                                    <strong>@header.Key</strong>
                                    <span>base64: @header.ValueBase64</span>
                                    @if (!string.IsNullOrWhiteSpace(header.Utf8Preview)) { <span>utf8: @header.Utf8Preview</span> }
                                    @if (!string.IsNullOrWhiteSpace(header.HexPreview)) { <span>hex: @header.HexPreview</span> }
                                </div>
                            }
                        }
                    </div>
                </div>
                <div>
                    <h4>Key</h4>
                    <div class="code-stack">
                        <label>
                            <span>Key Deserializer</span>
                            <select @bind="_keyDeserializer">
                                @foreach (var fmt in _deserializerFormats)
                                {
                                    <option value="@fmt">@fmt</option>
                                }
                            </select>
                        </label>
                        <label><span>Deserialized Key</span><textarea readonly rows="4">@DeserializeBytes(_selectedMessage.KeyBase64, _keyDeserializer)</textarea></label>
                    </div>
                    <h4>Body</h4>
                    <div class="code-stack">
                        <label>
                            <span>Value Deserializer</span>
                            <select @bind="_valueDeserializer">
                                @foreach (var fmt in _deserializerFormats)
                                {
                                    <option value="@fmt">@fmt</option>
                                }
                            </select>
                        </label>
                        <label><span>Deserialized Value</span><textarea readonly rows="8">@DeserializeBytes(_selectedMessage.ValueBase64, _valueDeserializer)</textarea></label>
                    </div>
                    <h4>Raw</h4>
                    <div class="code-stack">
                        <label><span>Key Base64</span><textarea readonly rows="2">@(_selectedMessage.KeyBase64 ?? "No key")</textarea></label>
                        <label><span>Value Base64</span><textarea readonly rows="3">@_selectedMessage.ValueBase64</textarea></label>
                        <label><span>Hex Preview</span><textarea readonly rows="3">@_selectedMessage.Preview?.ValueHexPreview</textarea></label>
                    </div>
                </div>
            </div>
        }
    </section>
</div>

@code {
    [Parameter]
    public string? ConnectionSessionId { get; set; }

    [Parameter]
    public EventCallback<string> OnSessionLost { get; set; }

    private readonly List<KafkaTopicSummary> _topics = [];
    private ViewSessionStatus _sessionStatus = new();
    private SteakMessageEnvelope? _selectedMessage;
    private string? _selectedTopic;
    private string _selectedPartitionValue = string.Empty;
    private string _topicFilter = string.Empty;
    private string _messageFilter = string.Empty;
    private string _groupId = string.Empty;
    private bool _loadingTopics;
    private string? _loadedSessionId;
    private string? _error;
    private MessageOffsetMode _offsetMode = MessageOffsetMode.Earliest;
    private string _keyDeserializer = "UTF-8 String";
    private string _valueDeserializer = "Pretty JSON";

    private static readonly string[] _deserializerFormats = [
        "UTF-8 String",
        "Pretty JSON",
        "Base64 (raw)",
        "Hex",
        "Int16 (Big-Endian)",
        "Int32 (Big-Endian)",
        "Int64 (Big-Endian)",
        "UInt16 (Big-Endian)",
        "UInt32 (Big-Endian)",
        "UInt64 (Big-Endian)",
        "Float (IEEE 754)",
        "Double (IEEE 754)",
        "UUID / GUID",
        "Unix Timestamp (s)",
        "Unix Timestamp (ms)",
        "Boolean",
        "Protobuf (wire)",
        "MessagePack (hex)",
        "URL-Encoded",
        "Latin-1 String"
    ];

    private KafkaTopicSummary? SelectedTopicSummary => _topics.FirstOrDefault(t => t.Name == _selectedTopic);
    private bool CanStart => !string.IsNullOrWhiteSpace(ConnectionSessionId) && !string.IsNullOrWhiteSpace(_selectedTopic);

    private List<KafkaTopicSummary> FilteredTopics => _topics
        .Where(t => string.IsNullOrWhiteSpace(_topicFilter) || t.Name.Contains(_topicFilter, StringComparison.OrdinalIgnoreCase))
        .OrderBy(t => t.Name).ToList();

    private List<SteakMessageEnvelope> FilteredMessages => _sessionStatus.RecentMessages
        .Where(m => string.IsNullOrWhiteSpace(_messageFilter)
            || m.ValueBase64.Contains(_messageFilter, StringComparison.OrdinalIgnoreCase)
            || (m.Preview?.ValueUtf8Preview?.Contains(_messageFilter, StringComparison.OrdinalIgnoreCase) ?? false)
            || (m.Topic?.Contains(_messageFilter, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderByDescending(m => m.Offset).ToList();

    protected override void OnInitialized()
    {
        _sessionStatus = ViewSessionService.Snapshot;
        ViewSessionService.StateChanged += HandleStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.Equals(_loadedSessionId, ConnectionSessionId, StringComparison.Ordinal)
            && !string.IsNullOrWhiteSpace(ConnectionSessionId))
        {
            _loadedSessionId = ConnectionSessionId;
            await RefreshTopicsAsync().ConfigureAwait(false);
        }
    }

    private async Task RefreshTopicsAsync()
    {
        _topics.Clear();
        _selectedTopic ??= string.Empty;
        _error = null;
        if (string.IsNullOrWhiteSpace(ConnectionSessionId)) return;

        try
        {
            _loadingTopics = true;
            var topics = await TopicBrowserService.ListTopicsAsync(ConnectionSessionId).ConfigureAwait(false);
            _topics.AddRange(topics);
            if (_topics.Count > 0 && !_topics.Any(t => t.Name == _selectedTopic))
                _selectedTopic = _topics[0].Name;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            if (ex.Message.Contains("No active connection session", StringComparison.OrdinalIgnoreCase))
                await OnSessionLost.InvokeAsync(ConnectionSessionId).ConfigureAwait(false);
        }
        finally
        {
            _loadingTopics = false;
            await InvokeAsync(StateHasChanged).ConfigureAwait(false);
        }
    }

    private async Task StartAsync()
    {
        if (!CanStart || string.IsNullOrWhiteSpace(ConnectionSessionId)) return;
        _error = null;
        try
        {
            var request = new StartViewSessionRequest
            {
                ConnectionSessionId = ConnectionSessionId,
                Topic = _selectedTopic!,
                Partition = int.TryParse(_selectedPartitionValue, out var p) ? p : null,
                OffsetMode = _offsetMode,
                GroupId = string.IsNullOrWhiteSpace(_groupId) ? null : _groupId.Trim(),
                MaxMessages = 0
            };
            _sessionStatus = await ViewSessionService.StartAsync(request).ConfigureAwait(false);
            _selectedMessage = _sessionStatus.RecentMessages.LastOrDefault();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task StopAsync()
    {
        await ViewSessionService.StopAsync().ConfigureAwait(false);
        _sessionStatus = ViewSessionService.Snapshot;
    }

    private void SelectTopic(string topic)
    {
        _selectedTopic = topic;
        _offsetMode = MessageOffsetMode.Earliest;
    }

    private void HandleStateChanged(object? sender, EventArgs e)
    {
        _sessionStatus = ViewSessionService.Snapshot;
        _selectedMessage ??= _sessionStatus.RecentMessages.LastOrDefault();
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose() => ViewSessionService.StateChanged -= HandleStateChanged;

    private static string DeserializeBytes(string? base64, string format)
    {
        if (string.IsNullOrWhiteSpace(base64)) return "(empty)";

        byte[] bytes;
        try { bytes = Convert.FromBase64String(base64); }
        catch { return $"Invalid base64: {base64[..Math.Min(base64.Length, 40)]}"; }

        if (bytes.Length == 0) return "(empty)";

        try
        {
            return format switch
            {
                "UTF-8 String" => System.Text.Encoding.UTF8.GetString(bytes),
                "Pretty JSON" => TryPrettyJson(bytes),
                "Base64 (raw)" => base64,
                "Hex" => BitConverter.ToString(bytes).Replace("-", " "),
                "Int16 (Big-Endian)" when bytes.Length >= 2 =>
                    System.Buffers.Binary.BinaryPrimitives.ReadInt16BigEndian(bytes).ToString(),
                "Int32 (Big-Endian)" when bytes.Length >= 4 =>
                    System.Buffers.Binary.BinaryPrimitives.ReadInt32BigEndian(bytes).ToString(),
                "Int64 (Big-Endian)" when bytes.Length >= 8 =>
                    System.Buffers.Binary.BinaryPrimitives.ReadInt64BigEndian(bytes).ToString(),
                "UInt16 (Big-Endian)" when bytes.Length >= 2 =>
                    System.Buffers.Binary.BinaryPrimitives.ReadUInt16BigEndian(bytes).ToString(),
                "UInt32 (Big-Endian)" when bytes.Length >= 4 =>
                    System.Buffers.Binary.BinaryPrimitives.ReadUInt32BigEndian(bytes).ToString(),
                "UInt64 (Big-Endian)" when bytes.Length >= 8 =>
                    System.Buffers.Binary.BinaryPrimitives.ReadUInt64BigEndian(bytes).ToString(),
                "Float (IEEE 754)" when bytes.Length >= 4 =>
                    BitConverter.ToSingle(bytes.Length == 4 ? bytes.Reverse().ToArray() : bytes[..4].Reverse().ToArray()).ToString("G"),
                "Double (IEEE 754)" when bytes.Length >= 8 =>
                    BitConverter.ToDouble(bytes.Length == 8 ? bytes.Reverse().ToArray() : bytes[..8].Reverse().ToArray()).ToString("G"),
                "UUID / GUID" when bytes.Length >= 16 => new Guid(bytes[..16]).ToString(),
                "Unix Timestamp (s)" when bytes.Length >= 4 =>
                    DateTimeOffset.FromUnixTimeSeconds(System.Buffers.Binary.BinaryPrimitives.ReadInt32BigEndian(bytes)).ToString("u"),
                "Unix Timestamp (ms)" when bytes.Length >= 8 =>
                    DateTimeOffset.FromUnixTimeMilliseconds(System.Buffers.Binary.BinaryPrimitives.ReadInt64BigEndian(bytes)).ToString("u"),
                "Boolean" when bytes.Length >= 1 => bytes[0] != 0 ? "true" : "false",
                "Protobuf (wire)" => FormatProtobufWire(bytes),
                "MessagePack (hex)" => $"MsgPack ({bytes.Length} bytes): {BitConverter.ToString(bytes[..Math.Min(bytes.Length, 64)]).Replace("-", " ")}{(bytes.Length > 64 ? "..." : "")}",
                "URL-Encoded" => System.Net.WebUtility.UrlEncode(System.Text.Encoding.UTF8.GetString(bytes)),
                "Latin-1 String" => System.Text.Encoding.Latin1.GetString(bytes),
                _ => $"Not enough bytes for {format} (have {bytes.Length})"
            };
        }
        catch (Exception ex)
        {
            return $"Decode error ({format}): {ex.Message}";
        }
    }

    private static string TryPrettyJson(byte[] bytes)
    {
        try
        {
            var text = System.Text.Encoding.UTF8.GetString(bytes);
            var doc = System.Text.Json.JsonDocument.Parse(text);
            return System.Text.Json.JsonSerializer.Serialize(doc.RootElement, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return System.Text.Encoding.UTF8.GetString(bytes);
        }
    }

    private static string FormatProtobufWire(byte[] bytes)
    {
        // Simple protobuf wire-format dumper: field/wiretype + raw values
        var sb = new System.Text.StringBuilder();
        int pos = 0;
        int fieldCount = 0;
        while (pos < bytes.Length && fieldCount < 50)
        {
            int tag = 0, shift = 0;
            while (pos < bytes.Length)
            {
                int b = bytes[pos++];
                tag |= (b & 0x7F) << shift;
                shift += 7;
                if ((b & 0x80) == 0) break;
            }
            int fieldNum = tag >> 3;
            int wireType = tag & 0x7;
            sb.Append($"field {fieldNum} (wire {wireType}): ");
            switch (wireType)
            {
                case 0: // varint
                    long v = 0; shift = 0;
                    while (pos < bytes.Length)
                    {
                        int b = bytes[pos++];
                        v |= (long)(b & 0x7F) << shift;
                        shift += 7;
                        if ((b & 0x80) == 0) break;
                    }
                    sb.AppendLine(v.ToString());
                    break;
                case 1: // 64-bit
                    if (pos + 8 <= bytes.Length)
                    {
                        sb.AppendLine(BitConverter.ToInt64(bytes, pos).ToString());
                        pos += 8;
                    }
                    break;
                case 2: // length-delimited
                    int len = 0; shift = 0;
                    while (pos < bytes.Length)
                    {
                        int b = bytes[pos++];
                        len |= (b & 0x7F) << shift;
                        shift += 7;
                        if ((b & 0x80) == 0) break;
                    }
                    if (pos + len <= bytes.Length)
                    {
                        var chunk = bytes[pos..(pos + len)];
                        var asStr = System.Text.Encoding.UTF8.GetString(chunk);
                        sb.AppendLine(asStr.All(c => !char.IsControl(c) || c == '\n' || c == '\r' || c == '\t')
                            ? $"\"{asStr}\""
                            : $"({len} bytes) {BitConverter.ToString(chunk[..Math.Min(chunk.Length, 16)]).Replace("-", " ")}");
                        pos += len;
                    }
                    break;
                case 5: // 32-bit
                    if (pos + 4 <= bytes.Length)
                    {
                        sb.AppendLine(BitConverter.ToInt32(bytes, pos).ToString());
                        pos += 4;
                    }
                    break;
                default:
                    sb.AppendLine("(unknown wire type)");
                    pos = bytes.Length;
                    break;
            }
            fieldCount++;
        }
        return sb.Length > 0 ? sb.ToString().TrimEnd() : "(empty protobuf or not protobuf)";
    }
}
