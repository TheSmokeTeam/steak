@implements IDisposable
@inject ILogger<ConsumeWorkspace> Logger
@inject IConsumeExportService ConsumeExportService
@inject ITopicBrowserService TopicBrowserService
@inject IFileNameFactory FileNameFactory
@inject ILocalFolderPicker FolderPicker
@inject IUiToastService ToastService

<div class="workspace-panel">
    <div class="panel-header">
        <div>
            <p class="section-kicker">Consume</p>
            <h2>Batch export</h2>
        </div>
        <button class="ghost-button" disabled="@string.IsNullOrWhiteSpace(ConnectionSessionId)" @onclick="RefreshTopicsAsync">Refresh Topics</button>
    </div>

    <h3>Batch Consume</h3>
    <div class="control-grid">
        <label>
            <span>Topic <span class="tooltip-icon">?<span class="tooltip-text">Kafka topic to consume messages from.
All partitions are read unless you select one below.
Messages are exported in the order they arrive.
Refresh Topics to reload the list from the cluster.
You must select a topic before starting.</span></span></span>
            <select @bind="_selectedTopic">
                <option value="">Select topic</option>
                @foreach (var topic in _topics.OrderBy(t => t.Name))
                {
                    <option value="@topic.Name">@topic.Name</option>
                }
            </select>
        </label>
        <label>
            <span>Partition <span class="tooltip-icon">?<span class="tooltip-text">Limit consumption to a single partition.
"All partitions" reads from every partition.
Useful for targeted debugging or replay.
Partition IDs are 0-based integers.
List is populated from the selected topic.</span></span></span>
            <select @bind="_partitionValue">
                <option value="">All partitions</option>
                @if (SelectedTopicSummary is not null)
                {
                    @foreach (var partition in SelectedTopicSummary.Partitions)
                    {
                        <option value="@partition.PartitionId">@partition.PartitionId</option>
                    }
                }
            </select>
        </label>
        <label>
            <span>Offset Mode <span class="tooltip-icon">?<span class="tooltip-text">Where to start reading in the partition.
Earliest — read all messages from the beginning.
Latest — only new messages after the consumer starts.
Stored — resume from the last committed offset.
Timestamp — start from a specific point in time.</span></span></span>
            <select @bind="_offsetMode">
                @foreach (var mode in Enum.GetValues<MessageOffsetMode>())
                {
                    <option value="@mode">@mode</option>
                }
            </select>
        </label>
        <label>
            <span>Max Messages (0 = unlimited) <span class="tooltip-icon">?<span class="tooltip-text">Stop consuming after this many messages.
Set to 0 for unlimited (runs until stopped).
Useful for sampling a fixed number of records.
The consumer commits offsets when it stops.
Combine with offset mode for precise replay.</span></span></span>
            <input type="number" @bind="_maxMessages" min="0" />
        </label>
        <label>
            <span>Messages / second (0 = unlimited) <span class="tooltip-icon">?<span class="tooltip-text">Throttle consumption to this rate.
Set to 0 for maximum throughput.
Useful to avoid overwhelming downstream systems.
The actual rate may be slightly lower.
Throttling is per consumer instance.</span></span></span>
            <input type="number" @bind="_messagesPerSecond" min="0" step="0.1" />
        </label>
    </div>

    <div class="control-grid">
        <label>
            <span>Destination Transport <span class="tooltip-icon">?<span class="tooltip-text">Where consumed messages are written.
FileSystem — saves JSON files to a local folder.
S3 — uploads JSON objects to an AWS S3 bucket.
Each message becomes one file with metadata.
File names include topic, partition, and timestamp.</span></span></span>
            <select @bind="_transportKind">
                @foreach (var kind in Enum.GetValues<BatchTransportKind>())
                {
                    <option value="@kind">@kind</option>
                }
            </select>
        </label>

        @if (_transportKind == BatchTransportKind.FileSystem)
        {
            <div class="field-stack">
                <span>Folder Path <span class="tooltip-icon">?<span class="tooltip-text">Local directory where exported files are saved.
The folder is created automatically if it doesn't exist.
Use the Browse button to choose the destination folder directly.
Each message is saved as a separate JSON file.
Absolute paths are recommended (e.g. D:\Exports).</span></span></span>
                <div class="browse-row">
                    <input @bind="_fsPath" placeholder="D:\KafkaExports" />
                    <button type="button" class="ghost-button browse-button" @onclick="BrowseDestinationFolderAsync">Browse</button>
                </div>
            </div>
        }
        else
        {
            <label>
                <span>S3 Bucket <span class="tooltip-icon">?<span class="tooltip-text">Name of the AWS S3 bucket for exported messages.
The bucket must already exist in your account.
Steak writes one object per consumed message.
Ensure the access key has s3:PutObject permission.
Bucket names are globally unique in AWS.</span></span></span>
                <input @bind="_s3Bucket" placeholder="my-bucket" />
            </label>
            <label>
                <span>S3 Region <span class="tooltip-icon">?<span class="tooltip-text">AWS region where the S3 bucket is located.
Must match the bucket's actual region.
Examples: us-east-1, eu-west-1, ap-southeast-1.
Using the wrong region causes access errors.
Defaults to us-east-1 if left empty.</span></span></span>
                <input @bind="_s3Region" placeholder="us-east-1" />
            </label>
            <label>
                <span>S3 Prefix <span class="tooltip-icon">?<span class="tooltip-text">Key prefix for objects written to S3.
Acts like a folder path inside the bucket.
Example: exports/ puts files under that prefix.
Trailing slash is recommended for clarity.
Leave blank to write to the bucket root.</span></span></span>
                <input @bind="_s3Prefix" placeholder="exports/" />
            </label>
            <label>
                <span>Access Key <span class="tooltip-icon">?<span class="tooltip-text">AWS IAM access key ID for S3 authentication.
Part of an IAM user or role credential pair.
Needs s3:PutObject permission on the target bucket.
Stored in memory only — never persisted to disk.
Use a dedicated service account for production.</span></span></span>
                <input @bind="_s3AccessKey" />
            </label>
            <label>
                <span>Secret Key <span class="tooltip-icon">?<span class="tooltip-text">AWS IAM secret access key paired with the above.
Keep this value confidential at all times.
Stored in memory only — never persisted to disk.
Rotate keys regularly per AWS best practices.
Use IAM roles instead of keys when possible.</span></span></span>
                <input type="password" @bind="_s3SecretKey" />
            </label>
        }
    </div>

    <div class="button-row">
        @if (_jobStatus.IsRunning)
        {
            <button class="stop-button" @onclick="StopAsync">&#9632; Stop Consuming</button>
        }
        else
        {
            <button class="start-button" disabled="@(!CanStart)" @onclick="StartAsync">&#9654; Start Consuming</button>
        }
        <span class="status-pill @(_jobStatus.IsRunning ? "live" : "idle")">
            @(_jobStatus.IsRunning ? $"{_jobStatus.ExportedCount} written" : "Idle")
        </span>
    </div>

    <ToastTray />

    <div class="metric-grid">
        <div class="metric-card"><strong>Exported</strong><span>@_jobStatus.ExportedCount</span></div>
        <div class="metric-card"><strong>Identity</strong><span>@EffectiveConsumerIdentity</span></div>
        <div class="metric-card"><strong>Throughput</strong><span>@_jobStatus.CurrentMessagesPerSecond.ToString("F1") msg/s</span></div>
        <div class="metric-card"><strong>Started</strong><span>@(_jobStatus.StartedAtUtc?.ToLocalTime().ToString("u") ?? "-")</span></div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="inline-alert danger">@_error</div>
    }

    <div class="workspace-columns">
        <section class="surface inner-surface">
            <div class="section-heading">
                <div><p class="section-kicker">Status</p><h3>@(_jobStatus.Topic ?? "No active job")</h3></div>
            </div>
            <div class="metadata-list">
                <div class="meta-card"><strong>Filename preview</strong><span>@BuildFileNamePreview()</span></div>
                <div class="meta-card"><strong>Partition scope</strong><span>@(string.IsNullOrWhiteSpace(_partitionValue) ? "All partitions" : $"Partition {_partitionValue}")</span></div>
                <div class="meta-card"><strong>Messages / second</strong><span>@_jobStatus.CurrentMessagesPerSecond.ToString("F1")</span></div>
                <div class="meta-card"><strong>Last destination</strong><span>@(_jobStatus.LastDestination ?? "Not written yet")</span></div>
                <div class="meta-card"><strong>Last error</strong><span>@(_jobStatus.LastError ?? "None")</span></div>
            </div>
        </section>
    </div>
</div>

@code {
    [Parameter]
    public string? ConnectionSessionId { get; set; }

    [Parameter]
    public EventCallback<string> OnSessionLost { get; set; }

    [Parameter]
    public string? Username { get; set; }

    private readonly List<KafkaTopicSummary> _topics = [];
    private ConsumeJobStatus _jobStatus = new();
    private string? _selectedTopic;
    private string _partitionValue = string.Empty;
    private string? _error;
    private string? _loadedSessionId;
    private MessageOffsetMode _offsetMode = MessageOffsetMode.Earliest;

    private BatchTransportKind _transportKind = BatchTransportKind.FileSystem;
    private string _fsPath = string.Empty;
    private string _s3Bucket = string.Empty;
    private string _s3Region = string.Empty;
    private string _s3Prefix = string.Empty;
    private string _s3AccessKey = string.Empty;
    private string _s3SecretKey = string.Empty;
    private int _maxMessages;
    private double _messagesPerSecond;
    private bool _stopRequested;

    private KafkaTopicSummary? SelectedTopicSummary => _topics.FirstOrDefault(t => t.Name == _selectedTopic);
    private string EffectiveConsumerIdentity => string.IsNullOrWhiteSpace(Username)
        ? (string.IsNullOrWhiteSpace(Environment.UserName) ? "steak" : Environment.UserName)
        : Username;
    private bool CanStart => !string.IsNullOrWhiteSpace(ConnectionSessionId)
        && !string.IsNullOrWhiteSpace(_selectedTopic)
        && (_transportKind != BatchTransportKind.FileSystem || !string.IsNullOrWhiteSpace(_fsPath))
        && (_transportKind != BatchTransportKind.S3 || !string.IsNullOrWhiteSpace(_s3Bucket));

    protected override void OnInitialized()
    {
        _jobStatus = ConsumeExportService.Snapshot;
        ConsumeExportService.StateChanged += HandleStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.Equals(_loadedSessionId, ConnectionSessionId, StringComparison.Ordinal)
            && !string.IsNullOrWhiteSpace(ConnectionSessionId))
        {
            _loadedSessionId = ConnectionSessionId;
            await RefreshTopicsAsync().ConfigureAwait(false);
        }
    }

    private async Task RefreshTopicsAsync()
    {
        _topics.Clear();
        _error = null;
        if (string.IsNullOrWhiteSpace(ConnectionSessionId)) return;

        try
        {
            var topics = await TopicBrowserService.ListTopicsAsync(ConnectionSessionId).ConfigureAwait(false);
            _topics.AddRange(topics);
            if (_topics.Count > 0 && !_topics.Any(t => t.Name == _selectedTopic))
            {
                _selectedTopic = _topics[0].Name;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Consume workspace failed to refresh topics for session {SessionId}", ConnectionSessionId);
            _error = UiErrorMessage.Build("Refresh topics", ex);
            if (ex.Message.Contains("No active connection session", StringComparison.OrdinalIgnoreCase))
                await OnSessionLost.InvokeAsync(ConnectionSessionId).ConfigureAwait(false);
        }
        finally { await InvokeAsync(StateHasChanged).ConfigureAwait(false); }
    }

    private BatchDestinationOptions BuildDestination() => _transportKind switch
    {
        BatchTransportKind.S3 => new BatchDestinationOptions
        {
            TransportKind = BatchTransportKind.S3,
            S3 = new S3LocationOptions
            {
                Bucket = _s3Bucket,
                Region = _s3Region,
                Prefix = _s3Prefix,
                AccessKey = _s3AccessKey,
                SecretKey = _s3SecretKey
            }
        },
        _ => new BatchDestinationOptions
        {
            TransportKind = BatchTransportKind.FileSystem,
            FileSystem = new FileSystemLocationOptions
            {
                Path = string.IsNullOrWhiteSpace(_fsPath) ? string.Empty : _fsPath.Trim()
            }
        }
    };

    private async Task StartAsync()
    {
        if (!CanStart || string.IsNullOrWhiteSpace(ConnectionSessionId)) return;
        _error = null;
        try
        {
            _stopRequested = false;
            var request = new CreateConsumeJobRequest
            {
                ConnectionSessionId = ConnectionSessionId,
                Topic = _selectedTopic!,
                GroupId = EffectiveConsumerIdentity,
                OffsetMode = _offsetMode,
                Partition = int.TryParse(_partitionValue, out var p) ? p : null,
                Destination = BuildDestination(),
                MaxMessages = _maxMessages > 0 ? _maxMessages : null,
                MessagesPerSecond = _messagesPerSecond > 0 ? _messagesPerSecond : null
            };
            _jobStatus = await ConsumeExportService.StartAsync(request).ConfigureAwait(false);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Consume workspace failed to start export job for session {SessionId}", ConnectionSessionId);
            _error = UiErrorMessage.Build("Start export", ex);
        }
    }

    private async Task StopAsync()
    {
        try
        {
            _stopRequested = true;
            await ConsumeExportService.StopAsync().ConfigureAwait(false);
            _jobStatus = ConsumeExportService.Snapshot;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Consume workspace failed to stop export job for session {SessionId}", ConnectionSessionId);
            _error = UiErrorMessage.Build("Stop export", ex);
        }
    }

    private string BuildFileNamePreview()
    {
        if (string.IsNullOrWhiteSpace(_selectedTopic))
            return "Steak_<topic>_p<partition>_o<offset>_<utc-timestamp>_<short-id>.json";

        return FileNameFactory.CreateMessageFileName(new SteakMessageEnvelope
        {
            Topic = _selectedTopic, Partition = 0, Offset = 42,
            CapturedAtUtc = DateTimeOffset.UtcNow,
            ValueBase64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes("preview"))
        });
    }

    private void HandleStateChanged(object? sender, EventArgs e)
    {
        var previousStatus = _jobStatus;
        _jobStatus = ConsumeExportService.Snapshot;

        if (previousStatus.IsRunning && !_jobStatus.IsRunning)
        {
            ShowCompletionToast(previousStatus, _jobStatus);
        }

        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose() => ConsumeExportService.StateChanged -= HandleStateChanged;

    private async Task BrowseDestinationFolderAsync()
    {
        try
        {
            var selectedPath = await FolderPicker.PickFolderAsync(_fsPath).ConfigureAwait(false);
            if (!string.IsNullOrWhiteSpace(selectedPath))
            {
                _fsPath = selectedPath;
                _error = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Consume workspace failed to open the folder picker");
            _error = UiErrorMessage.Build("Choose destination folder", ex);
        }
    }

    private static string FormatCount(long count, string noun)
    {
        return count == 1 ? $"1 {noun}" : $"{count} {noun}s";
    }

    private void ShowCompletionToast(ConsumeJobStatus previousStatus, ConsumeJobStatus currentStatus)
    {
        var wasStopped = _stopRequested;
        _stopRequested = false;

        if (!string.IsNullOrWhiteSpace(currentStatus.LastError))
        {
            ToastService.Show(
                UiToastKind.Danger,
                wasStopped ? "Consume stopped with error" : "Consume ended with error",
                currentStatus.LastError);
            return;
        }

        var title = wasStopped ? "Consume stopped" : "Consume finished";
        var verb = wasStopped ? "Stopped" : "Finished";

        ToastService.ShowInfo(
            title,
            $"{verb} consuming {previousStatus.Topic ?? "the selected topic"} after exporting {FormatCount(previousStatus.ExportedCount, "message")}.");
    }
}
